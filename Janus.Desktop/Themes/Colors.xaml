<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- NEON palette -->
    <Color x:Key="BgColor">#FF05060A</Color>
    <Color x:Key="Bg1Color">#FF0A0D14</Color>
    <Color x:Key="Bg2Color">#FF10141D</Color>
    <Color x:Key="Bg3Color">#FF161C26</Color>
    <Color x:Key="BorderColor">#FF1E2730</Color>
    <Color x:Key="BorderHotColor">#59B4FF00</Color>

    <Color x:Key="TextColor">#FFE6FFE9</Color>
    <Color x:Key="TextMuteColor">#FF7A8A7E</Color>
    <Color x:Key="TextDimColor">#FF4A5A4E</Color>

    <Color x:Key="NeonColor">#FFB4FF00</Color>
    <Color x:Key="NeonSoftColor">#1FB4FF00</Color>

    <Color x:Key="UpColor">#FF3DDC97</Color>
    <Color x:Key="DownColor">#FFFF4D6D</Color>
    <Color x:Key="WarnColor">#FFFFB300</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1Color}" />
    <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2Color}" />
    <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3Color}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderHotBrush" Color="{StaticResource BorderHotColor}" />

    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMuteBrush" Color="{StaticResource TextMuteColor}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}" />

    <SolidColorBrush x:Key="NeonBrush" Color="{StaticResource NeonColor}" />
    <SolidColorBrush x:Key="NeonSoftBrush" Color="{StaticResource NeonSoftColor}" />

    <SolidColorBrush x:Key="UpBrush" Color="{StaticResource UpColor}" />
    <SolidColorBrush x:Key="DownBrush" Color="{StaticResource DownColor}" />
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}" />

    <!-- Typography — JetBrains Mono is the single face used across the UI
         for a uniform feel. SansFont is kept as an alias in case we want to
         split later, but right now it's the same font. -->
    <x:String x:Key="MonoFont">ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono,Cascadia Mono,Consolas</x:String>
    <x:String x:Key="SansFont">ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono,Cascadia Mono,Consolas</x:String>

    <!-- WinUI theme overrides so controls whose text is rendered via the
         framework's default ContentPresenter (NavigationView items, ListView
         items, dialog content, etc.) also pick up JetBrains Mono. -->
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono,Cascadia Mono,Consolas</FontFamily>

</ResourceDictionary>
