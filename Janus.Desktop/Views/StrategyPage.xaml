<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Janus.Desktop.Views.StrategyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:services="using:Janus.Desktop.Services"
    xmlns:views="using:Janus.Desktop.Views"
    NavigationCacheMode="Required"
    Background="{StaticResource BgBrush}">

    <ScrollViewer Padding="20">
        <Grid RowSpacing="16" ColumnSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Rules -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel Spacing="10">
                    <Grid>
                        <TextBlock Text="// STRATEGY // RULES" Style="{StaticResource CardLabel}" />
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GhostButton}" Content="+ RULE" Click="AddRule_Click" />
                            <Button Style="{StaticResource GhostButton}" Content="CLEAR"  Click="ClearRules_Click" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="NAME" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="NameBox" MinWidth="200" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="TEMPLATE" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <ComboBox x:Name="TemplateBox" MinWidth="180"
                                      SelectionChanged="Template_Changed">
                                <ComboBoxItem Content="— none —" Tag="" />
                                <ComboBoxItem Content="EMA CROSS" Tag="ema_cross" />
                                <ComboBoxItem Content="RSI MEAN REV" Tag="rsi_mr" />
                                <ComboBoxItem Content="BB BREAKOUT" Tag="bb_breakout" />
                                <ComboBoxItem Content="SMA TREND" Tag="sma_trend" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <ItemsControl x:Name="RulesList"
                                  Background="{StaticResource Bg2Brush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="1"
                                  Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="services:StratRule">
                                <Grid Padding="4,3" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{x:Bind views:StrategyPage.IndicatorList}"
                                              SelectedItem="{x:Bind Indicator, Mode=TwoWay}"
                                              Padding="8,4,8,4" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{x:Bind views:StrategyPage.OpList}"
                                              SelectedItem="{x:Bind Op, Mode=TwoWay}"
                                              Padding="8,4,8,4" />
                                    <TextBox Grid.Column="2"
                                             Text="{x:Bind Value, Mode=TwoWay}"
                                             Padding="8,4,8,4" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{x:Bind views:StrategyPage.ActionList}"
                                              SelectedItem="{x:Bind Action, Mode=TwoWay}"
                                              Padding="8,4,8,4" />
                                    <Button Grid.Column="4"
                                            Content="✕"
                                            Style="{StaticResource GhostButton}"
                                            Tag="{x:Bind}"
                                            Click="RemoveRule_Click"
                                            Padding="8,2,8,2" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SYMBOL" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="SymbolBox" MinWidth="180" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="TF" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <ComboBox x:Name="TfBox">
                                <ComboBoxItem Content="5m"  />
                                <ComboBoxItem Content="15m" />
                                <ComboBoxItem Content="1h" IsSelected="True" />
                                <ComboBoxItem Content="1d"  />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Style="{StaticResource NeonButton}" Content="RUN BACKTEST" Click="RunBacktest_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Settings -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel Spacing="10">
                    <TextBlock Text="// SETTINGS" Style="{StaticResource CardLabel}" />
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="INITIAL CAPITAL" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="CapitalBox" Text="100000" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="POSITION SIZE %" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="PosBox" Text="100" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="COMMISSION %" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="FeeBox" Text="0.05" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="STOP LOSS %" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="SlBox" Text="3" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="TAKE PROFIT %" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="TpBox" Text="6" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                            <TextBlock Text="SLIPPAGE %" Style="{StaticResource Muted}" CharacterSpacing="200" />
                            <TextBox x:Name="SlipBox" Text="0.03" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- AI GENERATE -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <StackPanel Spacing="10">
                    <Grid>
                        <TextBlock Text="// AI // GENERATE" Style="{StaticResource CardLabel}" />
                        <TextBlock x:Name="AiState" Text="idle" Style="{StaticResource Muted}"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AiPrompt"
                                 PlaceholderText="describe a strategy — e.g. 'mean-reversion on oversold RSI in uptrends'"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="60" />
                        <Button Grid.Column="1"
                                Style="{StaticResource NeonButton}"
                                Content="GENERATE"
                                Click="GenerateAi_Click"
                                VerticalAlignment="Stretch" />
                    </Grid>
                    <TextBox x:Name="AiOutput"
                             Visibility="Collapsed"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MaxHeight="200"
                             FontSize="11"
                             Foreground="{StaticResource TextMuteBrush}" />
                </StackPanel>
            </Border>

            <!-- Equity curve -->
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="// EQUITY CURVE" Style="{StaticResource CardLabel}" />
                        <TextBlock x:Name="EquityState" Text="run a backtest to see equity"
                                   Style="{StaticResource Muted}" HorizontalAlignment="Right" />
                    </Grid>
                    <Border Background="{StaticResource Bg2Brush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Height="220">
                        <lvc:CartesianChart x:Name="EquityChart"
                                            LegendPosition="Hidden"
                                            ZoomMode="X"
                                            ZoomingSpeed="0.5" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Performance KPIs -->
            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <StackPanel Spacing="10">
                    <TextBlock Text="// PERFORMANCE" Style="{StaticResource CardLabel}" />
                    <ItemsControl x:Name="KpiRepeater">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Trade list -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="// TRADE LIST" Style="{StaticResource CardLabel}" />
                        <TextBlock x:Name="TradeCount" Style="{StaticResource Muted}" HorizontalAlignment="Right" />
                    </Grid>
                    <ListView x:Name="TradesList" Background="Transparent" SelectionMode="None" MaxHeight="360">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="6,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="EXIT TIME" Style="{StaticResource Muted}" CharacterSpacing="250" />
                                    <TextBlock Text="SIDE"      Style="{StaticResource Muted}" CharacterSpacing="250" Grid.Column="1" />
                                    <TextBlock Text="ENTRY"     Style="{StaticResource Muted}" CharacterSpacing="250" Grid.Column="2" />
                                    <TextBlock Text="EXIT"      Style="{StaticResource Muted}" CharacterSpacing="250" Grid.Column="3" />
                                    <TextBlock Text="PNL"       Style="{StaticResource Muted}" CharacterSpacing="250" Grid.Column="4" />
                                    <TextBlock Text="PNL%"      Style="{StaticResource Muted}" CharacterSpacing="250" Grid.Column="5" />
                                    <TextBlock Text="RSN"       Style="{StaticResource Muted}" CharacterSpacing="250" Grid.Column="6" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:BacktestTrade">
                                <Grid Padding="6,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ExitTime}" Style="{StaticResource Mono}" />
                                    <TextBlock Text="{x:Bind Side}"     Style="{StaticResource Mono}" FontWeight="SemiBold" Grid.Column="1" />
                                    <TextBlock Text="{x:Bind Entry}"    Style="{StaticResource Mono}" Grid.Column="2" />
                                    <TextBlock Text="{x:Bind Exit}"     Style="{StaticResource Mono}" Grid.Column="3" />
                                    <TextBlock Text="{x:Bind Pnl}"      Style="{StaticResource Mono}" Grid.Column="4" />
                                    <TextBlock Text="{x:Bind PnlPct}"   Style="{StaticResource Mono}" Grid.Column="5" />
                                    <TextBlock Text="{x:Bind Reason}"   Style="{StaticResource Muted}" Grid.Column="6" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                       x:Name="ErrorText" Style="{StaticResource Muted}"
                       Foreground="{StaticResource DownBrush}" />
        </Grid>
    </ScrollViewer>
</Page>
