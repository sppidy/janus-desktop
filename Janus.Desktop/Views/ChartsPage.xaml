<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Janus.Desktop.Views.ChartsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    NavigationCacheMode="Required"
    Background="{StaticResource BgBrush}">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Symbol + TF -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="SYMBOL" Style="{StaticResource Muted}" CharacterSpacing="250"
                           VerticalAlignment="Center" />
                <AutoSuggestBox x:Name="SymbolBox"
                                MinWidth="260"
                                PlaceholderText="type (e.g. TATASTEEL.NS)"
                                TextChanged="SymbolBox_TextChanged"
                                SuggestionChosen="SymbolBox_SuggestionChosen"
                                QuerySubmitted="SymbolBox_QuerySubmitted" />
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}" Content="5m"  Click="Tf_Click" Tag="5m" />
                    <Button Style="{StaticResource GhostButton}" Content="15m" Click="Tf_Click" Tag="15m" />
                    <Button x:Name="Tf1h" Style="{StaticResource NeonButton}" Content="1h" Click="Tf_Click" Tag="1h" />
                    <Button Style="{StaticResource GhostButton}" Content="1d" Click="Tf_Click" Tag="1d" />
                </StackPanel>
                <TextBlock x:Name="LegendText" Style="{StaticResource Mono}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Indicator toggles -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,10">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <ToggleButton x:Name="MaToggle" Content="MA20"    Click="Ind_Click" Tag="ma20"  Style="{StaticResource GhostToggle}" />
                <ToggleButton x:Name="EmaToggle" Content="EMA50"  Click="Ind_Click" Tag="ema50" Style="{StaticResource GhostToggle}" />
                <ToggleButton x:Name="BbToggle" Content="BB"      Click="Ind_Click" Tag="bb"    Style="{StaticResource GhostToggle}" />
                <ToggleButton x:Name="VolToggle" Content="VOL" IsChecked="True" Click="Ind_Click" Tag="vol"   Style="{StaticResource GhostToggle}" />
                <ToggleButton x:Name="RsiToggle" Content="RSI" IsChecked="True" Click="Ind_Click" Tag="rsi"   Style="{StaticResource GhostToggle}" />
            </StackPanel>
        </Border>

        <!-- Chart grid (main + RSI sub-pane) -->
        <Grid Grid.Row="2" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="2">
                <lvc:CartesianChart x:Name="MainChart"
                                    Background="{StaticResource Bg2Brush}"
                                    LegendPosition="Hidden"
                                    ZoomMode="X"
                                    ZoomingSpeed="0.5" />
            </Border>

            <Border x:Name="RsiBorder" Grid.Row="1" Style="{StaticResource Card}" Padding="2">
                <lvc:CartesianChart x:Name="RsiChart"
                                    Background="{StaticResource Bg2Brush}"
                                    LegendPosition="Hidden"
                                    ZoomMode="X"
                                    ZoomingSpeed="0.5" />
            </Border>
        </Grid>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="2"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"
                   Margin="0,0,12,12"
                   Style="{StaticResource Muted}"
                   Foreground="{StaticResource DownBrush}" />
    </Grid>
</Page>
