<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NEON.Trader.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:NEON.Trader.Desktop.Views"
    Title="NEON.TRADER">

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar / backend switcher.
             ExtendsContentIntoTitleBar=true is set in code-behind, so this
             Grid IS the title bar. Right-most column reserves space for the
             OS-rendered min/max/close buttons (~140 px). -->
        <Grid x:Name="AppTitleBar" Grid.Row="0"
              Background="{StaticResource Bg1Brush}"
              Height="44"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="148" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0" Spacing="8">
                <Image Source="ms-appx:///Assets/neon.ico" Width="20" Height="20"
                       VerticalAlignment="Center" />
                <TextBlock Text="NEON"
                           FontFamily="{StaticResource SansFont}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
                <Ellipse Width="10" Height="10"
                         Fill="{StaticResource NeonBrush}"
                         VerticalAlignment="Center" />
                <TextBlock Text="TRADER"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11" CharacterSpacing="300"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuteBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        Spacing="8" Margin="0,0,16,0">
                <TextBlock Text="BACKEND"
                           Style="{StaticResource Muted}"
                           CharacterSpacing="200"
                           VerticalAlignment="Center" />
                <ComboBox x:Name="BackendCombo"
                          MinWidth="180"
                          SelectionChanged="BackendCombo_SelectionChanged" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                        Spacing="6" Margin="0,0,16,0">
                <Border Padding="8,3" Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse x:Name="ConnDot" Width="8" Height="8"
                                 Fill="{StaticResource DownBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="ConnText" Text="OFFLINE"
                                   Style="{StaticResource Muted}"
                                   CharacterSpacing="200" />
                    </StackPanel>
                </Border>
                <Border Padding="8,3" Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="REGIME"
                                   Style="{StaticResource Muted}"
                                   CharacterSpacing="200" />
                        <TextBlock x:Name="RegimeText" Text="—"
                                   Style="{StaticResource Mono}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Navigation -->
        <muxc:NavigationView
            Grid.Row="1"
            x:Name="Nav"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="200"
            Background="{StaticResource BgBrush}"
            SelectionChanged="Nav_SelectionChanged"
            ItemInvoked="Nav_ItemInvoked">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="DASHBOARD" Tag="dash">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="WATCHLIST" Tag="watch">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="PORTFOLIO" Tag="port">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8C7;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="CHARTS" Tag="chart">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="STRATEGY" Tag="strat">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C1;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="SCANNER" Tag="scan">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE721;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="AGENT" Tag="agent">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="LOGS" Tag="logs">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9F9;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="SETTINGS" Tag="set">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>

        <InfoBar x:Name="ToastBar"
                 Grid.Row="1"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Right"
                 Margin="0,0,24,24"
                 IsOpen="False" />
    </Grid>
</Window>
