<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Implicit defaults: every text-bearing control gets the NEON mono font
         unless explicitly overridden. -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>
    <Style TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>
    <Style TargetType="HyperlinkButton">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>
    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>
    <Style TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>

    <!-- Section label (e.g. DASHBOARD //). Uppercase is applied at the
         TextBlock.Text source, since WinUI 3 TextBlock has no TextTransform. -->
    <Style x:Key="CardLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="200" />
        <Setter Property="Foreground" Value="{StaticResource TextMuteBrush}" />
    </Style>

    <!-- KPI value big number -->
    <Style x:Key="KpiValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SansFont}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <!-- Muted small text -->
    <Style x:Key="Muted" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextMuteBrush}" />
    </Style>

    <!-- Body mono text -->
    <Style x:Key="Mono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <!-- Card surface -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Bg1Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- Primary lime button override -->
    <Style x:Key="NeonButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource NeonBrush}" />
        <Setter Property="Foreground" Value="#FF0A0F00" />
        <Setter Property="BorderBrush" Value="{StaticResource NeonBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="150" />
        <Setter Property="Padding" Value="14,8,14,8" />
    </Style>

    <!-- Ghost / secondary button -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="150" />
        <Setter Property="Padding" Value="12,6,12,6" />
    </Style>

    <!-- Same visual as GhostButton but for ToggleButton controls (e.g. chart
         indicator toggles). TargetType has to match the applied element's type. -->
    <Style x:Key="GhostToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="150" />
        <Setter Property="Padding" Value="12,6,12,6" />
    </Style>

    <!-- Themed TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,8,10,8" />
    </Style>

    <!-- Themed PasswordBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,8,10,8" />
    </Style>

    <!-- Themed ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,6,10,6" />
    </Style>

    <!-- Vertical stack defaults -->
    <Style x:Key="Stack" TargetType="StackPanel">
        <Setter Property="Spacing" Value="10" />
    </Style>

</ResourceDictionary>
