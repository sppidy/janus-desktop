<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NEON.Trader.Desktop.Views.AgentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NEON.Trader.Desktop.Models"
    NavigationCacheMode="Required"
    Background="{StaticResource BgBrush}">

    <Grid Padding="20">
        <Border Style="{StaticResource Card}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <TextBlock Text="// AGENT" Style="{StaticResource CardLabel}" VerticalAlignment="Center" />
                    <TextBlock x:Name="StateText"
                               HorizontalAlignment="Right"
                               Style="{StaticResource Muted}" />
                </Grid>

                <!-- Chat log -->
                <Border Grid.Row="1"
                        Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        MinHeight="420">
                    <ListView x:Name="ChatList"
                              Background="Transparent"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ChatMessageVm">
                                <StackPanel Spacing="4" Padding="6,8,6,8">
                                    <TextBlock Text="{x:Bind RoleLabel}"
                                               Foreground="{x:Bind RoleBrush}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="10"
                                               CharacterSpacing="300"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Body}"
                                               Style="{StaticResource Mono}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Input bar -->
                <Grid Grid.Row="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InputBox"
                             Grid.Column="0"
                             PlaceholderText="Ask the agent..."
                             KeyDown="Input_KeyDown" />
                    <Button Grid.Column="1"
                            x:Name="SendBtn"
                            Style="{StaticResource NeonButton}"
                            Content="SEND"
                            Click="Send_Click" />
                </Grid>

                <TextBlock Grid.Row="3"
                           x:Name="ErrorText"
                           Style="{StaticResource Muted}"
                           Foreground="{StaticResource DownBrush}" />
            </Grid>
        </Border>
    </Grid>
</Page>
