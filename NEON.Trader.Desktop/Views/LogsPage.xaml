<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NEON.Trader.Desktop.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NEON.Trader.Desktop.Models"
    NavigationCacheMode="Required"
    Background="{StaticResource BgBrush}">

    <Grid Padding="20">
        <Border Style="{StaticResource Card}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header row -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="// LOGS" Style="{StaticResource CardLabel}" VerticalAlignment="Center" />
                        <Border x:Name="StatusPill"
                                Background="Transparent"
                                BorderBrush="{StaticResource DownBrush}"
                                BorderThickness="1"
                                Padding="8,2,8,2">
                            <TextBlock x:Name="StatusPillText"
                                       Text="DISCONNECTED"
                                       Style="{StaticResource Muted}"
                                       Foreground="{StaticResource DownBrush}"
                                       CharacterSpacing="200" />
                        </Border>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource GhostButton}"
                            Content="CLEAR"
                            Click="Clear_Click" />
                </Grid>

                <!-- Log stream -->
                <Border Grid.Row="1"
                        Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <ScrollViewer x:Name="LogScroller"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="LogBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MinHeight="400" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
